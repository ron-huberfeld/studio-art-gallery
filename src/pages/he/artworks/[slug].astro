---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import LanguageSwitcher from '../../../components/LanguageSwitcher.astro';
import { getArtworkCta, getArtworkDescription, getArtworkTitle, listArtworks } from '../../../lib/artwork';
import { createInquiryHref } from '../../../lib/inquiry';

export function getStaticPaths() {
  return listArtworks().map((artwork) => ({ params: { slug: artwork.slug }, props: { artwork } }));
}

const locale = 'he';
const { artwork } = Astro.props;
const title = getArtworkTitle(artwork, locale);
const description = getArtworkDescription(artwork, locale);
const cta = getArtworkCta(artwork, locale);
const href = createInquiryHref(title, locale);
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const imageSrc = `${base}${artwork.images[0].replace(/^\//, '')}`;
---

<BaseLayout title={`${title} · Atelier Gallery`} locale={locale} description={description || 'יצירה בעבודת יד'}>
  <main>
    <LanguageSwitcher locale={locale} slug={artwork.slug} />
    <article class="detail-card">
      <img src={imageSrc} alt={title} />
      <p class="status">{cta.label}</p>
      <h1>{title}</h1>
      {description && <p>{description}</p>}
      {cta.enabled && <a class="cta" href={href}>{cta.label}</a>}
    </article>
  </main>
</BaseLayout>
