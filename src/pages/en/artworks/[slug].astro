---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import LanguageSwitcher from '../../../components/LanguageSwitcher.astro';
import { getArtworkCta, getArtworkDescription, getArtworkPriceLabel, getArtworkStatusLabel, getArtworkTitle, listArtworks } from '../../../lib/artwork';
import { createInquiryHref } from '../../../lib/inquiry';
import { getSiteTitle } from '../../../lib/i18n';

export function getStaticPaths() {
  return listArtworks().map((artwork) => ({ params: { slug: artwork.slug }, props: { artwork } }));
}

const locale = 'en';
const { artwork } = Astro.props;
const siteTitle = getSiteTitle(locale);
const title = getArtworkTitle(artwork, locale);
const description = getArtworkDescription(artwork, locale);
const cta = getArtworkCta(artwork, locale);
const href = createInquiryHref(title, locale);
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const imageSrc = `${base}${artwork.images[0].replace(/^\//, '')}`;
const statusLabel = getArtworkStatusLabel(artwork, locale);
const priceLabel = getArtworkPriceLabel(artwork, locale);
---

<BaseLayout
  title={`${title} · ${siteTitle}`}
  locale={locale}
  currentPath={`/en/artworks/${artwork.slug}/`}
  alternatePath={`/he/artworks/${artwork.slug}/`}
  description={description || 'Handmade artwork'}
>
  <main>
    <LanguageSwitcher locale={locale} slug={artwork.slug} />
    <article class="detail-card">
      <img src={imageSrc} alt={title} loading="eager" />
      <p class="status">{statusLabel}</p>
      <h1>{title}</h1>
      {priceLabel && <p class="price">{priceLabel}</p>}
      {description && <p>{description}</p>}
      {cta.enabled && <a class="cta" href={href}>{cta.label}</a>}
    </article>
  </main>
</BaseLayout>
